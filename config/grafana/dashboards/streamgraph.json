{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Kafka Throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(kafka_producer_record_send_total[1m])",
          "legendFormat": "producer send/s",
          "refId": "A"
        }
      ],
      "title": "Kafka Producer Throughput (records/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "rate(kafka_consumer_records_consumed_total[1m])",
          "legendFormat": "consumer consume/s",
          "refId": "A"
        }
      ],
      "title": "Kafka Consumer Throughput (records/s)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Generator",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "ops",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "yellow", "value": 100 },
            { "color": "green", "value": 200 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 10 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "rate(streamgraph_transactions_generated_total[1m])",
          "legendFormat": "tx/s",
          "refId": "A"
        }
      ],
      "title": "Transactions / sec",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 10 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 10 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "streamgraph_active_fraud_rings",
          "legendFormat": "rings",
          "refId": "A"
        }
      ],
      "title": "Active Fraud Rings",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 10 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "streamgraph_transactions_generated_total",
          "legendFormat": "total",
          "refId": "A"
        }
      ],
      "title": "Total Transactions Generated",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 0.05 },
            { "color": "red", "value": 0.15 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 10 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "streamgraph_fraud_ring_ratio",
          "legendFormat": "ratio",
          "refId": "A"
        }
      ],
      "title": "Fraud Ring Ratio",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Risk Scores & Alerts",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "ops"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "critical" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "high" },     "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "medium" },   "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "low" },      "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 7,
      "targets": [
        { "expr": "rate(streamgraph_alerts_total{severity=\"critical\"}[1m])", "legendFormat": "critical", "refId": "A" },
        { "expr": "rate(streamgraph_alerts_total{severity=\"high\"}[1m])",     "legendFormat": "high",     "refId": "B" },
        { "expr": "rate(streamgraph_alerts_total{severity=\"medium\"}[1m])",   "legendFormat": "medium",   "refId": "C" },
        { "expr": "rate(streamgraph_alerts_total{severity=\"low\"}[1m])",      "legendFormat": "low",      "refId": "D" }
      ],
      "title": "Alerts / sec by Severity",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 8,
      "targets": [
        { "expr": "streamgraph_risk_score_p50", "legendFormat": "p50", "refId": "A" },
        { "expr": "streamgraph_risk_score_p95", "legendFormat": "p95", "refId": "B" },
        { "expr": "streamgraph_risk_score_p99", "legendFormat": "p99", "refId": "C" }
      ],
      "title": "Risk Score Percentiles",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "id": 9,
      "targets": [
        { "expr": "rate(streamgraph_rules_triggered_total[1m])", "legendFormat": "{{rule}}", "refId": "A" }
      ],
      "title": "Rule Triggers / sec",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "Entity Graph",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 10,
      "targets": [
        { "expr": "streamgraph_components_total", "legendFormat": "total components", "refId": "A" },
        { "expr": "streamgraph_entities_total",   "legendFormat": "total entities",   "refId": "B" }
      ],
      "title": "Entity Graph Size",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 11,
      "targets": [
        { "expr": "streamgraph_component_size_p50", "legendFormat": "p50 size", "refId": "A" },
        { "expr": "streamgraph_component_size_p95", "legendFormat": "p95 size", "refId": "B" },
        { "expr": "streamgraph_component_size_max", "legendFormat": "max size", "refId": "C" }
      ],
      "title": "Component Size Distribution",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 104,
      "title": "Fraud Confirmations",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 41 },
      "id": 12,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        { "expr": "streamgraph_fraud_confirmations_total", "legendFormat": "confirmed", "refId": "A" }
      ],
      "title": "Total Confirmed Fraud Components",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "ops",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 0.1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 41 },
      "id": 13,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        { "expr": "rate(streamgraph_r09_triggers_total[5m])", "legendFormat": "r09/s", "refId": "A" }
      ],
      "title": "R09 Triggers / sec (guilt-by-assoc.)",
      "type": "stat"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["streamgraph", "fraud"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "StreamGraph — Fraud Detection",
  "uid": "streamgraph-main",
  "version": 1
}
